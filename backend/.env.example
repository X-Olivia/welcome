OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_BASE_URL=https://api.chatanywhere.tech/v1
# 前端公网地址（生成二维码链接；手机扫码需能访问该地址）
PUBLIC_BASE_URL=https://welcome-unnc.netlify.app
# 生产环境前端域名也要加入 CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://welcome-unnc.netlify.app
# 无真机时保持 true，仅打印机械臂指令
ARM_MOCK=true
